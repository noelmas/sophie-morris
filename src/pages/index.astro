---
import Layout from '../layouts/Layout.astro';
import Cutouts from '../components/Cutouts.astro';
import {
  profile,
  experience,
  films,
  publications,
  education,
  fellowships,
} from '../data/profile';
---

<Layout title={`${profile.name} — ${profile.title}`} description={profile.tagline}>
  <Cutouts />

  <header class="topbar">
    <div class="wrap topbar__inner">
      <a class="topbar__name" href="#top">{profile.name}</a>
      <nav class="nav">
        <a href="#about">About</a>
        <a href="#publications">Publications</a>
        <a href="#film">Film</a>
        <a href="#experience">Experience</a>
        <a href="#education">Education</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="hero">
      <div class="wrap">
        <p class="hero__eyebrow">{profile.title}</p>
        <h1 class="hero__tagline">{profile.tagline}</h1>
        <div class="hero__meta">
          <span>{profile.location}</span>
          <span>PhD, History of Art, UCL</span>
          <a class="hero__handle" href={profile.instagram} target="_blank" rel="noopener">
            {profile.instagramHandle} ↗
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="section" id="about">
      <div class="wrap">
        <p class="section__label">About</p>
        <div class="prose reveal">
          {profile.intro.map((para) => <p>{para}</p>)}
        </div>
      </div>
    </section>

    <!-- Publications & Projects -->
    <section class="section" id="publications">
      <div class="wrap">
        <p class="section__label">Selected Publications &amp; Projects</p>
        <div class="writing reveal">
          {
            publications.map((p) => (
              <article class="work">
                <span class="work__period">{p.year}</span>
                <p class="work__entry">
                  {p.url ? (
                    <a class="work__link" href={p.url} target="_blank" rel="noopener">
                      {p.title} ↗
                    </a>
                  ) : (
                    <span class="work__title">{p.title}</span>
                  )}<span class="work__meta">, {p.outlet}{p.role ? ` · ${p.role}` : ''}</span>
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Film -->
    <section class="section" id="film">
      <div class="wrap">
        <p class="section__label">Film</p>
        {
          films.map((f) => (
            <div class="film reveal">
              <div class="film__frame">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${f.youtubeId}`}
                  title={f.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              </div>
              <div class="film__caption">
                <h2 class="film__title">{f.title}</h2>
                <p class="film__note">{f.note}</p>
                <a class="film__link" href={f.url} target="_blank" rel="noopener">
                  Watch on YouTube — {f.publisher} ↗
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Experience -->
    <section class="section" id="experience">
      <div class="wrap">
        <p class="section__label">Experience</p>
        {
          experience.map((org) => (
            <div class="org reveal">
              <div class="org__head">
                <h2 class="org__name">{org.organisation}</h2>
                <span class="org__meta">
                  {[org.meta, org.location].filter(Boolean).join(' · ')}
                </span>
              </div>
              <ul class="roles">
                {org.roles.map((role) => (
                  <li class="role">
                    <span class="role__period">{role.period}</span>
                    <p class="role__entry">
                      <span class="role__title">{role.title}</span>
                      {role.detail && <span class="role__detail"> — {role.detail}</span>}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education + Fellowships -->
    <section class="section" id="education">
      <div class="wrap cols">
        <div class="reveal">
          <p class="section__label">Education</p>
          {
            education.map((e) => (
              <div class="edu">
                <span class="edu__period">{e.period}</span>
                <p class="edu__entry">
                  <span class="edu__qual">{e.qualification}</span>, {e.institution}
                  {e.detail && <span class="edu__note"> · {e.detail}</span>}
                </p>
              </div>
            ))
          }
        </div>
        <div class="reveal">
          <p class="section__label">Fellowships &amp; Grants</p>
          <ul class="grants">
            {
              fellowships.map((f) => (
                <li class="grant">
                  <span class="grant__period">{f.period}</span>
                  <span class="grant__text">{f.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer / contact -->
  <footer class="footer" id="contact">
    <div class="wrap">
      {
        profile.email ? (
          <a class="footer__contact" href={`mailto:${profile.email}`}>
            {profile.email} →
          </a>
        ) : (
          <a class="footer__contact" href={profile.instagram} rel="noopener">
            Connect on Instagram →
          </a>
        )
      }
      <ul class="footer__links">
        <li>
          <a href={profile.instagram} target="_blank" rel="noopener">
            Instagram, {profile.instagramHandle} ↗
          </a>
        </li>
      </ul>
      <div class="footer__base">
        <span>© {profile.name}</span>
        <span>{profile.location}</span>
      </div>
    </div>
  </footer>
</Layout>
