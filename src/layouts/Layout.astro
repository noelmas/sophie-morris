---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {/* Staging: keep this out of search engines. Remove when going live. */}
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90' font-family='Georgia,serif'%3ESM%3C/text%3E%3C/svg%3E" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Subtle reveal-on-scroll for sections.
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-visible'));
      }

      // Show a hairline under the sticky bar once scrolled.
      const bar = document.querySelector('.topbar');
      if (bar) {
        const onScroll = () =>
          bar.style.setProperty(
            'border-bottom-color',
            window.scrollY > 8 ? 'var(--line)' : 'transparent'
          );
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // Collapsible sections: reveal content the moment a fold opens, and
      // auto-open a section when it's targeted from the top-nav links.
      const folds = document.querySelectorAll('.fold');
      folds.forEach((fold) => {
        fold.addEventListener('toggle', () => {
          if (fold.open) {
            fold
              .querySelectorAll('.reveal')
              .forEach((el) => el.classList.add('is-visible'));
          }
        });
      });

      const openSection = (id) => {
        if (!id) return;
        const section = document.getElementById(id);
        const fold = section && section.querySelector('.fold');
        if (fold && !fold.open) fold.open = true;
      };
      openSection(location.hash.slice(1));
      window.addEventListener('hashchange', () =>
        openSection(location.hash.slice(1))
      );

      // Top-nav clicks expand the target section (even when re-clicked).
      document.querySelectorAll('.nav a[href^="#"]').forEach((link) => {
        link.addEventListener('click', () => {
          openSection(link.getAttribute('href').slice(1));
        });
      });
    </script>
  </body>
</html>
